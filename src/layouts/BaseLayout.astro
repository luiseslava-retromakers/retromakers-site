---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  // Absolute or root-relative URL for the social/link preview image.
  // Falls back to the site-wide default below when a page doesn't set one.
  image?: string;
}
const {
  title,
  description = 'Fun facts and stories from 80s, 90s, and 2000s video games.',
  noindex = false,
  image = '/social-preview.png',
} = Astro.props;

const GA_MEASUREMENT_ID = 'G-9LX3ZR8S1H';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Retromakers</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="yDvVRkZk3PtPRH48mREonIVPuBi5YKhZGQP9qqVHdhY" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content={`${title} · Retromakers`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    {import.meta.env.PROD && (
      <>
        {/*
          IMPORTANT: this consent + dataLayer setup script MUST run BEFORE the
          gtag.js library script tag below. Google's Consent Mode requires the
          default consent state to be queued up before the library loads — if
          gtag.js initializes first (which can happen since it loads via
          `async`), it locks in "no consent state defined" and silently drops
          all hits, even though the library itself loads fine. Do not reorder
          these two script tags.
        */}
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag(...args) {
            window.dataLayer.push(args);
          };
          // We don't run ads or remarketing, so we deny ad-related storage and
          // only grant basic analytics storage (page views, events).
          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: 'granted',
          });
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID);
        </script>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
      </>
    )}
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />
  </body>
</html>
