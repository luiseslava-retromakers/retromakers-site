---
const year = new Date().getFullYear();

const social = [
  { name: 'X', href: 'https://x.com/retromakers_' },
  { name: 'TikTok', href: 'https://www.tiktok.com/@retromakers' },
  { name: 'YouTube', href: 'https://www.youtube.com/@retromakersmx' },
  { name: 'Instagram', href: null }, // coming soon — no account yet
];
---

<footer>
  <div class="container footer-inner">
    <p>&copy; {year} Retromakers. All game titles, screenshots, and artwork referenced belong to their respective owners.</p>

    <div class="social-icons">
      {social.map((s) =>
        s.href ? (
          <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.name} title={s.name}>
            {s.name === 'X' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.9 2h3.3l-7.2 8.2L23.5 22h-6.8l-5.3-6.9L5 22H1.7l7.7-8.8L1 2h6.9l4.8 6.3L18.9 2Zm-1.2 18h1.8L7.4 3.9H5.5L17.7 20Z"/></svg>
            )}
            {s.name === 'TikTok' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M16.6 2h-3.2v13.7a3 3 0 1 1-2.1-2.9V9.5a6.2 6.2 0 1 0 5.3 6.1V8.4a7.9 7.9 0 0 0 4.6 1.5V6.6a4.8 4.8 0 0 1-4.6-4.6Z"/></svg>
            )}
            {s.name === 'YouTube' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M22 12s0-3.2-.4-4.7a2.9 2.9 0 0 0-2-2C17.9 5 12 5 12 5s-5.9 0-7.6.3a2.9 2.9 0 0 0-2 2C2 8.8 2 12 2 12s0 3.2.4 4.7a2.9 2.9 0 0 0 2 2C6.1 19 12 19 12 19s5.9 0 7.6-.3a2.9 2.9 0 0 0 2-2c.4-1.5.4-4.7.4-4.7ZM10 15.5v-7l6 3.5-6 3.5Z"/></svg>
            )}
            {s.name === 'Instagram' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2 0 1.9.3 2.3.5a4.6 4.6 0 0 1 1.7 1.1 4.6 4.6 0 0 1 1.1 1.7c.2.4.4 1.1.5 2.3.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c0 1.2-.3 1.9-.5 2.3a4.6 4.6 0 0 1-1.1 1.7 4.6 4.6 0 0 1-1.7 1.1c-.4.2-1.1.4-2.3.5-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2 0-1.9-.3-2.3-.5a4.6 4.6 0 0 1-1.7-1.1 4.6 4.6 0 0 1-1.1-1.7c-.2-.4-.4-1.1-.5-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c0-1.2.3-1.9.5-2.3a4.6 4.6 0 0 1 1.1-1.7 4.6 4.6 0 0 1 1.7-1.1c.4-.2 1.1-.4 2.3-.5C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.1 0-3.5 0-4.7.1-1 0-1.5.2-1.9.4-.5.2-.8.4-1.1.7-.3.3-.5.6-.7 1.1-.2.4-.3.9-.4 1.9-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 1 .2 1.5.4 1.9.2.5.4.8.7 1.1.3.3.6.5 1.1.7.4.2.9.3 1.9.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1 0 1.5-.2 1.9-.4.5-.2.8-.4 1.1-.7.3-.3.5-.6.7-1.1.2-.4.3-.9.4-1.9.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-1-.2-1.5-.4-1.9a2.8 2.8 0 0 0-.7-1.1 2.8 2.8 0 0 0-1.1-.7c-.4-.2-.9-.3-1.9-.4-1.2-.1-1.6-.1-4.7-.1Zm0 3.4a4.6 4.6 0 1 1 0 9.2 4.6 4.6 0 0 1 0-9.2Zm0 1.8a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6Zm5.8-3.2a1.1 1.1 0 1 1-2.2 0 1.1 1.1 0 0 1 2.2 0Z"/></svg>
            )}
          </a>
        ) : (
          <span class="social-placeholder" aria-label="Instagram (próximamente)" title="Instagram — próximamente">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2 0 1.9.3 2.3.5a4.6 4.6 0 0 1 1.7 1.1 4.6 4.6 0 0 1 1.1 1.7c.2.4.4 1.1.5 2.3.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c0 1.2-.3 1.9-.5 2.3a4.6 4.6 0 0 1-1.1 1.7 4.6 4.6 0 0 1-1.7 1.1c-.4.2-1.1.4-2.3.5-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2 0-1.9-.3-2.3-.5a4.6 4.6 0 0 1-1.7-1.1 4.6 4.6 0 0 1-1.1-1.7c-.2-.4-.4-1.1-.5-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c0-1.2.3-1.9.5-2.3a4.6 4.6 0 0 1 1.1-1.7 4.6 4.6 0 0 1 1.7-1.1c.4-.2 1.1-.4 2.3-.5C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.1 0-3.5 0-4.7.1-1 0-1.5.2-1.9.4-.5.2-.8.4-1.1.7-.3.3-.5.6-.7 1.1-.2.4-.3.9-.4 1.9-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 1 .2 1.5.4 1.9.2.5.4.8.7 1.1.3.3.6.5 1.1.7.4.2.9.3 1.9.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1 0 1.5-.2 1.9-.4.5-.2.8-.4 1.1-.7.3-.3.5-.6.7-1.1.2-.4.3-.9.4-1.9.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-1-.2-1.5-.4-1.9a2.8 2.8 0 0 0-.7-1.1 2.8 2.8 0 0 0-1.1-.7c-.4-.2-.9-.3-1.9-.4-1.2-.1-1.6-.1-4.7-.1Zm0 3.4a4.6 4.6 0 1 1 0 9.2 4.6 4.6 0 0 1 0-9.2Zm0 1.8a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6Zm5.8-3.2a1.1 1.1 0 1 1-2.2 0 1.1 1.1 0 0 1 2.2 0Z"/></svg>
          </span>
        )
      )}
    </div>

    <nav>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</footer>

<style>
  footer {
    background: var(--color-near-black);
    color: var(--color-cream);
    padding: 1.5rem 0;
    margin-top: 3rem;
    font-size: 0.85rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }
  footer nav {
    display: flex;
    gap: 1rem;
  }
  footer a {
    color: var(--color-cream);
    opacity: 0.85;
  }
  footer a:hover {
    color: var(--color-copper);
    opacity: 1;
  }
  .social-icons {
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }
  .social-icons a {
    display: flex;
    opacity: 0.85;
  }
  .social-icons a:hover {
    color: var(--color-copper);
    opacity: 1;
  }
  .social-placeholder {
    display: flex;
    opacity: 0.35;
    cursor: default;
  }
</style>
