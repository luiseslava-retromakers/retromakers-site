---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <article class="prose-page">
    <h1>About Retromakers</h1>
    <p>
      Retromakers is a home for the stories behind the games we grew up with — the 80s, 90s,
      and 2000s. Every article and game entry is built around the same idea: video game history
      is full of great trivia, and it's more fun shared than forgotten.
    </p>
    <p>
      Edit this page with your own story — who's behind Retromakers, why you started it, and
      what makes a game worth writing about.
    </p>
  </article>
</BaseLayout>

<style>
  .prose-page {
    max-width: 680px;
    margin: 2rem auto;
  }
</style>
