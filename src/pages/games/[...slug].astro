---
import { getCollection, render } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const games = await getCollection('games', ({ data }) => !data.draft);
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props;
const { Content } = await render(game);

// If this game entry has a cover image, generate an optimized version and use
// its URL as the social/link preview thumbnail (og:image) for this page.
const ogImage = game.data.coverImage
  ? (await getImage({ src: game.data.coverImage, width: 1200 })).src
  : undefined;
---

<BaseLayout title={game.data.title} image={ogImage}>
  <article>
    <h1>{game.data.title}</h1>
    <p class="meta">
      {game.data.platform.join(', ')} &middot; {game.data.releaseYear}
      {game.data.developer && <> &middot; Developed by {game.data.developer}</>}
    </p>

    <div>
      {game.data.genre.map((g: string) => <span class="tag">{g}</span>)}
    </div>

    {game.data.coverImage && (
      <Image
        src={game.data.coverImage}
        alt={game.data.coverImageAlt ?? game.data.title}
        widths={[400, 800, 1200]}
        sizes="(max-width: 680px) 100vw, 680px"
        class="cover-image"
      />
    )}

    <div class="prose">
      <Content />
    </div>

    {game.data.funFacts.length > 0 && (
      <section>
        <h2>Fun Facts</h2>
        {game.data.funFacts.map((fact: string) => (
          <div class="fun-fact">{fact}</div>
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  article {
    max-width: 680px;
    margin: 2rem auto;
  }
  .meta {
    font-family: var(--font-mono);
    color: var(--color-copper-deep);
  }
  .prose {
    margin: 1rem 0;
  }
  .cover-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin-top: 1rem;
  }
</style>
